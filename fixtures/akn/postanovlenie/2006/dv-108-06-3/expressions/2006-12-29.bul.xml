            <p>1.             от 0,01 до 0,50 м включително                                                                                                     0,18</p>
            <p>2.             над 0,50 до 1,00 м включително                                                                                                   0,26</p>
            <p>3.             над 1,00 до 1,50 м включително                                                                                                   0,41</p>
            <p>4.             над 1,50 до 2,00 м включително                                                                                                   0,59</p>
            <p>5.             над 2,00 до 2,50 м включително                                                                                                   0,77</p>
            <p>6.             над 2,50 до 3,50 м включително                                                                                                   1,14</p>
            <p>7.             над 3,50 м                                                                                                                              1,14+1,00</p>
            <p>за всеки</p>
            <p>започнат</p>
            <p>метър</p>
            <p>над 3,50 м</p>
            <p>”</p>
